{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../..",
    "paths": {
      "*": ["./*"],
      "@mariozechner/pi-ai": ["../ai/src/index.ts"],
      "@mariozechner/pi-ai/*": ["../ai/src/*.ts", "../ai/src/providers/*.ts"],
      "@mariozechner/pi-agent-core": ["../agent/src/index.ts"],
      "@mariozechner/pi-agent-core/*": ["../agent/src/*"],
      "@mariozechner/pi-tui": ["../tui/src/index.ts"],
      "@mariozechner/pi-tui/*": ["../tui/src/*"],
      "@mariozechner/pi-web-ui": ["./src/index.ts"],
      "@mariozechner/pi-web-ui/*": ["./src/*"],
      "typebox": ["../../node_modules/typebox"],
      "typebox/*": ["../../node_modules/typebox/*"]
    }
  },
  "include": ["src/**/*"]
}
